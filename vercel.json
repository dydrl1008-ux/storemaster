{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "headers": [
    {
      "source": "/tag-extractor.html",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-eval' 'unsafe-inline'"
        }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/product-info.html", "dest": "/product-info.html" },
    { "src": "/tag-extractor.html", "dest": "/tag-extractor.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
