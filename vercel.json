{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "headers": [
    {
      "source": "/tag-extractor.html",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/product-info.html", "dest": "/product-info.html" },
    { "src": "/tag-extractor.html", "dest": "/tag-extractor.html" },
    { "src": "/name-maker.html", "dest": "/name-maker.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
